<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /

  # If the request is for an existing file or directory, serve it directly
  RewriteCond %{REQUEST_FILENAME} -f [OR]
  RewriteCond %{REQUEST_FILENAME} -d
  RewriteRule ^ - [L]

  # Route /api/* requests to the PHP files
  RewriteRule ^api/(.*)$ api/$1 [L]

  # Route robots.txt, sitemap.xml, llms.txt, and llms-full.txt to dynamic GEO handler
  RewriteRule ^robots\.txt$ api/llms.php?mode=robots [L,QSA]
  RewriteRule ^sitemap\.xml$ api/llms.php?mode=sitemap [L,QSA]
  RewriteRule ^llms\.txt$ api/llms.php?mode=summary [L,QSA]
  RewriteRule ^llms-full\.txt$ api/llms.php?mode=full [L,QSA]
  RewriteRule ^llms-products\.txt$ api/llms.php?mode=products [L,QSA]
  RewriteRule ^llms-portfolio\.txt$ api/llms.php?mode=portfolio [L,QSA]
  RewriteRule ^llms-edukasi\.txt$ api/llms.php?mode=edukasi [L,QSA]
  RewriteRule ^llms-about\.txt$ api/llms.php?mode=about [L,QSA]
  RewriteRule ^llms-faq\.txt$ api/llms.php?mode=faq [L,QSA]
  RewriteRule ^llms-contact\.txt$ api/llms.php?mode=contact [L,QSA]
  RewriteRule ^llms-official-channels\.txt$ api/llms.php?mode=official-channels [L,QSA]
  RewriteRule ^llms-guide\.txt$ api/llms.php?mode=guide [L,QSA]

  # For all other routes, serve serve.php (SPA routing)
  RewriteRule ^ serve.php [L]
</IfModule>

# ── Security Headers ──────────────────────────────────────────────────
<IfModule mod_headers.c>
  Header set X-Content-Type-Options "nosniff"
  Header set X-Frame-Options "SAMEORIGIN"
  Header set X-XSS-Protection "1; mode=block"
  Header set Referrer-Policy "strict-origin-when-cross-origin"
</IfModule>

# ── Caching ───────────────────────────────────────────────────────────
<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresByType text/css "access plus 1 year"
  ExpiresByType application/javascript "access plus 1 year"
  ExpiresByType image/png "access plus 1 year"
  ExpiresByType image/jpeg "access plus 1 year"
  ExpiresByType image/gif "access plus 1 year"
  ExpiresByType image/svg+xml "access plus 1 year"
  ExpiresByType image/webp "access plus 1 year"
  ExpiresByType font/woff2 "access plus 1 year"
  ExpiresByType font/woff "access plus 1 year"
</IfModule>

# ── Compression ───────────────────────────────────────────────────────
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/css text/markdown application/javascript application/json image/svg+xml
</IfModule>
